<Window x:Class="ClipperApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipperApp" Height="680" Width="820"
        MinHeight="600" MinWidth="720"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titelleiste -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="ClipperApp" Foreground="{StaticResource TextBrush}"
                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Width="40" Height="40" Click="Minimize_Click"
                            Background="Transparent" Foreground="{StaticResource SubtextBrush}"
                            BorderThickness="0" FontSize="16" Cursor="Hand"/>
                    <Button Content="✕" Width="40" Height="40" Click="Close_Click"
                            Background="Transparent" Foreground="{StaticResource SubtextBrush}"
                            BorderThickness="0" FontSize="14" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Hauptinhalt -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Links: Status + Clips -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status-Karte -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="10" Padding="20" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Aufnahme-Status" Foreground="{StaticResource SubtextBrush}"
                                       FontSize="12" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusDot" Width="12" Height="12"
                                         Fill="{StaticResource SubtextBrush}" Margin="0,0,10,0"/>
                                <TextBlock x:Name="StatusLabel" Text="Nicht aktiv"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock x:Name="HotkeyLabel" Text="Hotkey: Alt+F9"
                                       Foreground="{StaticResource SubtextBrush}"
                                       FontSize="12" Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnStartStop" Content="⏹  Stoppen"
                                    Style="{StaticResource DangerButton}"
                                    Click="BtnStartStop_Click" Margin="0,0,8,0"/>
                            <Button x:Name="BtnSaveClip" Content="✂  Clip speichern"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnSaveClip_Click" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Benachrichtigung -->
                <Border Grid.Row="1" x:Name="NotificationBorder"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <TextBlock x:Name="NotificationLabel" FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Clips-Liste -->
                <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="10" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Gespeicherte Clips"
                                   Foreground="{StaticResource SubtextBrush}"
                                   FontSize="12" Margin="0,0,0,12"/>

                        <ListBox x:Name="ClipsList" Grid.Row="1"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}" FontSize="13"
                                 SelectionChanged="ClipsList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TimeText}"
                                                   Foreground="{StaticResource SubtextBrush}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"    Value="10,6"/>
                                    <Setter Property="Margin"     Value="0,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Clip-Aktionen -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button x:Name="BtnOpenClip" Content="▶  Öffnen"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnOpenClip_Click" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button Content="📁  Ordner öffnen"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnOpenFolder_Click"/>
                    <Button x:Name="BtnDeleteClip" Content="🗑  Löschen"
                            Style="{StaticResource DangerButton}"
                            Click="BtnDeleteClip_Click" IsEnabled="False" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Rechts: Einstellungen -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel>
                        <TextBlock Text="Einstellungen" Foreground="{StaticResource TextBrush}"
                                   FontSize="15" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Label Content="Clip-Dauer (Sekunden)"/>
                        <TextBox x:Name="TxtClipDuration" Margin="0,0,0,14"/>

                        <Label Content="Aufnahme-FPS"/>
                        <ComboBox x:Name="CmbFps" Margin="0,0,0,14">
                            <ComboBoxItem Content="24"/>
                            <ComboBoxItem Content="30"/>
                            <ComboBoxItem Content="60"/>
                        </ComboBox>

                        <Label Content="Clips-Ordner"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutputFolder" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="..." Width="32" Margin="4,0,0,0"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnBrowseFolder_Click"/>
                        </Grid>

                        <Label Content="FFmpeg-Pfad"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtFfmpegPath"/>
                            <Button Grid.Column="1" Content="..." Width="32" Margin="4,0,0,0"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnBrowseFfmpeg_Click"/>
                        </Grid>

                        <Label Content="Hotkey"/>
                        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6"
                                Padding="10,8" Margin="0,0,0,14"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TxtHotkeyDisplay" Text="Alt + F9"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                                <TextBlock Text="Modifier" Foreground="{StaticResource SubtextBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbModifier" Margin="0,0,0,8"
                                          SelectionChanged="CmbModifier_SelectionChanged">
                                    <ComboBoxItem Content="Alt"      Tag="1"/>
                                    <ComboBoxItem Content="Ctrl"     Tag="2"/>
                                    <ComboBoxItem Content="Shift"    Tag="4"/>
                                    <ComboBoxItem Content="Alt+Shift" Tag="5"/>
                                    <ComboBoxItem Content="Ctrl+Alt" Tag="3"/>
                                </ComboBox>

                                <TextBlock Text="Taste" Foreground="{StaticResource SubtextBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbKey" SelectionChanged="CmbKey_SelectionChanged">
                                    <ComboBoxItem Content="F1"  Tag="112"/>
                                    <ComboBoxItem Content="F2"  Tag="113"/>
                                    <ComboBoxItem Content="F3"  Tag="114"/>
                                    <ComboBoxItem Content="F4"  Tag="115"/>
                                    <ComboBoxItem Content="F5"  Tag="116"/>
                                    <ComboBoxItem Content="F6"  Tag="117"/>
                                    <ComboBoxItem Content="F7"  Tag="118"/>
                                    <ComboBoxItem Content="F8"  Tag="119"/>
                                    <ComboBoxItem Content="F9"  Tag="120"/>
                                    <ComboBoxItem Content="F10" Tag="121"/>
                                    <ComboBoxItem Content="F11" Tag="122"/>
                                    <ComboBoxItem Content="F12" Tag="123"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,4,0,14"/>

                        <!-- Audio -->
                        <TextBlock Text="Audio" Foreground="{StaticResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <CheckBox x:Name="ChkSystemAudio" Content="System-Audio (PC-Töne)"
                                  Margin="0,0,0,6"
                                  Checked="ChkAudio_Changed" Unchecked="ChkAudio_Changed"/>
                        <StackPanel x:Name="SysAudioPanel" Visibility="Collapsed" Margin="0,0,0,10">
                            <Label Content="System-Audio-Gerät"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CmbSystemAudio"/>
                                <Button Grid.Column="1" Content="↻" Width="32" Margin="4,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnRefreshAudio_Click" ToolTip="Geräte neu laden"/>
                            </Grid>
                            <TextBlock TextWrapping="Wrap" FontSize="10" Margin="0,4,0,0"
                                       Foreground="{StaticResource SubtextBrush}">
                                <Run Text="Tipp: "/>
                                <Run Text="Stereo Mix" FontWeight="SemiBold"/>
                                <Run Text=" wählen. Falls nicht sichtbar: Soundeinstellungen → Aufnahme → Rechtsklick → Deaktivierte Geräte anzeigen → Stereo Mix aktivieren."/>
                            </TextBlock>
                        </StackPanel>

                        <CheckBox x:Name="ChkMicrophone" Content="Mikrofon"
                                  Margin="0,0,0,6"
                                  Checked="ChkAudio_Changed" Unchecked="ChkAudio_Changed"/>
                        <StackPanel x:Name="MicPanel" Visibility="Collapsed" Margin="0,0,0,4">
                            <Label Content="Mikrofon-Gerät"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CmbMicrophone"/>
                                <Button Grid.Column="1" Content="↻" Width="32" Margin="4,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnRefreshAudio_Click" ToolTip="Geräte neu laden"/>
                            </Grid>
                        </StackPanel>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,8,0,14"/>

                        <Button Content="Einstellungen speichern"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnSaveSettings_Click"/>

                        <Border Margin="0,14,0,0" Background="{StaticResource BackgroundBrush}"
                                CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="FFmpeg Status" Foreground="{StaticResource SubtextBrush}"
                                           FontSize="11" Margin="0,0,0,6"/>
                                <TextBlock x:Name="FfmpegStatusLabel" FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SubtextBrush}"/>
                                <Button Content="📋  FFmpeg-Log öffnen" Margin="0,8,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnOpenLog_Click" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
